# OpenClaw workspace sync (safe defaults)

# OS / editor
.DS_Store
*.swp
*.tmp

# Logs / sessions (do not sync)
**/sessions/
**/*.jsonl

# Backups & archives
*.tar.gz

# Credentials / secrets (defense in depth)
.credentials
**/credentials/
**/.env
**/*.key
**/*token*

# Ignore nested workspace clones
workspace\ DailyBrief/
workspace\ Githuber/
workspace\ Installer/
workspace\ LINE\ Family/
workspace\ Learner/
workspace\ Moltbook/
workspace\ Rednoter/
workspace\ installer/

# Ignore virtual environment
.venv
.venv/
